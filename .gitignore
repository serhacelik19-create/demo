# Root Gitignore for Agentic Architecture Showcase Portfolio

# Dependencies (Global)
node_modules/
**/node_modules/

# Next.js build output
.next/
**/.next/
out/
build/
dist/
**/dist/


# Local databases (SQLite / Dev DBs)
*.db
*.db-journal
**/dev.db
**/dev.db-journal

# Environmental variables (CRITICAL SECURITY)
.env
.env*
.env.local
.env.production
.env.development
**/.env
**/.env*

# OS-generated files
.DS_Store
Thumbs.db

# IDE configurations
.vscode/
.idea/

# Local build logs & debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
